# Скопируйте в .env и заполните значения:
#   cp .env.example .env

# ── Обязательно ───────────────────────────────────────────────────
# Случайные строки; сгенерировать можно командой:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=ЗАМЕНИТЕ_НА_СЛУЧАЙНУЮ_СТРОКУ
API_SECRET=ЗАМЕНИТЕ_НА_ДРУГУЮ_СТРОКУ

# ── Только для docker-compose.postgres.yml ────────────────────────
POSTGRES_PASSWORD=ЗАМЕНИТЕ_НА_ПАРОЛЬ_БД

# ── SMTP (опционально) ────────────────────────────────────────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@email.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM=your@email.com
